    "hono": "^4.12.21",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260519.1",
    "@hono/node-server": "^1.19.14",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.93.0"
  }
}
